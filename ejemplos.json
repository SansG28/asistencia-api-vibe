  "reportes": {
    "GET_ausentismo": {
      "descripcion": "Obtener el Top 5 de estudiantes con más ausencias",
      "metodo": "GET",
      "url": "http://localhost:3000/api/reportes/ausentismo",
      "headers": {},
      "notas": [
        "Se cuentan como faltas: estado 'ausente' + estado 'justificada'",
        "Se ordena por cantidad de faltas (descendente)",
        "Se devuelven los 5 estudiantes con mayor ausentismo",
        "Incluye porcentaje de ausencia y desglose de presentes/ausentes/justificadas"
      ],
      "respuesta_exitosa": {
        "status": 200,
        "body": {
          "success": true,
          "message": "Reporte de ausentismo obtenido exitosamente",
          "data": [
            {
              "ranking": 1,
              "id": "EST00002",
              "nombre": "María López",
              "email": "maria.lopez@example.com",
              "totalAsistencias": 10,
              "presentes": 6,
              "ausencias": 3,
              "justificadas": 1,
              "totalFaltas": 4,
              "porcentajeAusencia": 40
            },
            {
              "ranking": 2,
              "id": "EST00001",
              "nombre": "Juan García",
              "email": "juan.garcia@example.com",
              "totalAsistencias": 12,
              "presentes": 10,
              "ausencias": 1,
              "justificadas": 1,
              "totalFaltas": 2,
              "porcentajeAusencia": 17
            }
          ],
          "total": 2
        }
      },
      "algoritmo_calculo": [
        "1. Se cuenta el total de registros de asistencia por estudiante",
        "2. Se categoriza cada registro por estado (presente/ausente/justificada)",
        "3. Se calcula totalFaltas = ausencias + justificadas",
        "4. Se calcula porcentajeAusencia = (totalFaltas / totalAsistencias) * 100",
        "5. Se ordena DESC por totalFaltas, luego DESC por porcentajeAusencia",
        "6. Se retorna solo el Top 5"
      ]
    }
  },

