  "asistencias": {
    "POST_registrar": {
      "descripcion": "Registrar una nueva asistencia",
      "metodo": "POST",
      "url": "http://localhost:3000/api/asistencias",
      "headers": {
        "Content-Type": "application/json"
      },
      "body": {
        "id_estudiante": "EST00001",
        "fecha": "2024-04-20",
        "estado": "presente"
      },
      "notas": [
        "La fecha debe estar en formato YYYY-MM-DD (ISO 8601)",
        "Los estados permitidos son: 'presente', 'ausente', 'justificada'",
        "La fecha no puede ser futura",
        "No se puede registrar dos asistencias para el mismo estudiante en la misma fecha"
      ],
      "respuesta_exitosa": {
        "status": 201,
        "body": {
          "success": true,
          "message": "Asistencia registrada exitosamente",
          "data": {
            "id": 4,
